# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/abu_al_yazid

# Session Secret (should be at least 32 characters)
SESSION_SECRET=your-secret-key-change-this-in-production

# Replit Auth (for production)
REPLIT_CLIENT_ID=your_replit_client_id
REPLIT_CLIENT_SECRET=your_replit_client_secret
REPLIT_CALLBACK_URL=http://localhost:5000/api/auth/callback

# AI Integration (Replit AI)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Custom API Keys (if not using Replit AI)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Other AI Providers
GOOGLE_API_KEY=your_google_api_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# File Upload Configuration
MAX_UPLOAD_SIZE=52428800

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com
